# RMN Hurricane Dashboard — example environment file.
# Copy to `.env` and fill in values. `.env` is git-ignored.

# ---- Runtime ----
ENV=development
DEBUG=true
LOG_LEVEL=INFO
HOST=127.0.0.1
PORT=8000

# ---- Database ----
# Dev default (SQLite). Render/Railway will inject a Postgres URL in prod.
# DATABASE_URL=sqlite:///./data/rmn_dashboard.db
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/rmn_dashboard

# ---- Kalshi (authenticated API) ----
# Get credentials at https://kalshi.com/account/profile
# KALSHI_API_KEY_ID=
# KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi_private_key.pem
# KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# ---- SEC EDGAR ----
# SEC requires a descriptive User-Agent containing contact info.
SEC_USER_AGENT=Risk Market News research@riskmarketnews.com

# ---- Scheduler ----
# Set true in production; false in dev to avoid background fetches.
SCHEDULER_ENABLED=false
